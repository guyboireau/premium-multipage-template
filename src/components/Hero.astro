---
// Hero — 3 variantes
// A : Centré · eyebrow → H1 → sous-titre → 2 CTAs → trust strip
// B : Asymétrique · texte gauche (55%) + image droite + badge flottant
// C : Full-bleed éditorial · image plein cadre + H1 overlay + infos dessous
import { variants, hero } from '../config/site';

const v = variants.hero;
---

{/* ── Variante A : centré classique ──────────────────────────────────── */}
<section class="hero hero-a section v-only-a" id="hero-a">
  <div class="container hero-a-inner">
    <p class="eyebrow hero-eyebrow">{hero.eyebrow}</p>
    <h1 class="hero-a-h1">{hero.h1}</h1>
    <p class="hero-a-sub">{hero.subtitle}</p>
    <div class="hero-a-actions">
      <a href={hero.cta1.href} class="btn btn-primary btn-lg">{hero.cta1.label}</a>
      <a href={hero.cta2.href} class="btn btn-outline btn-lg">{hero.cta2.label}</a>
    </div>
    <div class="trust-strip">
      <p class="eyebrow trust-label">Ils nous font confiance</p>
      <div class="trust-items">
        {hero.trust.map(t => (
          <span class="trust-item">{t}</span>
        ))}
      </div>
    </div>
  </div>
</section>

{/* ── Variante B : asymétrique texte + image ─────────────────────────── */}
<section class="hero hero-b section v-only-b" id="hero-b">
  <div class="container hero-b-inner">
    <div class="hero-b-text">
      <p class="eyebrow hero-eyebrow">{hero.eyebrow}</p>
      <h1 class="hero-b-h1">{hero.h1}</h1>
      <p class="hero-b-sub">{hero.subtitle}</p>
      <div class="hero-b-actions">
        <a href={hero.cta1.href} class="btn btn-primary btn-lg">{hero.cta1.label}</a>
        <a href={hero.cta2.href} class="btn btn-outline btn-lg">{hero.cta2.label}</a>
      </div>
      <div class="hero-b-meta">
        <div class="hero-b-divider"></div>
        <div class="hero-b-author">
          <span class="author-avatar" aria-hidden="true"></span>
          <div>
            <p class="author-name">{hero.badge.label}</p>
            <p class="author-sub eyebrow">{hero.badge.sub}</p>
          </div>
        </div>
      </div>
    </div>
    <div class="hero-b-visual">
      <div class="hero-b-img img-placeholder" aria-label="Image principale"></div>
      <div class="hero-b-badge">
        <p class="badge-label eyebrow">{hero.badge.label}</p>
        <p class="badge-value">{hero.badge.value}</p>
        <div class="stars" aria-label="5 étoiles">
          {'★★★★★'.split('').map(s => <span class="star">{s}</span>)}
        </div>
      </div>
    </div>
  </div>
</section>

{/* ── Variante C : full-bleed éditorial ─────────────────────────────── */}
<section class="hero hero-c v-only-c" id="hero-c">
  <div class="hero-c-visual img-placeholder" aria-label="Image principale">
    <div class="hero-c-overlay"></div>
    <div class="hero-c-eyebrow-wrap">
      <p class="eyebrow hero-c-eyebrow-pill">{hero.eyebrow}</p>
    </div>
    <div class="hero-c-h1-wrap">
      <h1 class="hero-c-h1">{hero.h1}</h1>
    </div>
  </div>
  <div class="hero-c-below section">
    <div class="container hero-c-below-inner">
      <div class="hero-c-text">
        <p class="hero-c-sub">{hero.subtitle}</p>
        <div class="hero-c-actions">
          <a href={hero.cta1.href} class="btn btn-primary btn-lg">{hero.cta1.label}</a>
          <a href={hero.cta2.href} class="btn btn-outline btn-lg">{hero.cta2.label}</a>
        </div>
      </div>
      <div class="hero-c-infocard">
        <p class="eyebrow" style="color: var(--inkFaint)">{hero.infoCard.status}</p>
        <p class="infocard-hours">{hero.infoCard.hours}</p>
        <p class="infocard-location text-muted">{hero.infoCard.location}</p>
      </div>
    </div>
  </div>
</section>

<style>
/* ─── Commun ────────────────────────────────────────────────────────────── */
.hero-eyebrow { margin-bottom: 20px; }

/* ─── Variante A ─────────────────────────────────────────────────────────── */
.hero-a { padding-top: calc(68px + clamp(64px, 10vw, 120px)); }
.hero-a-inner {
  display: flex; flex-direction: column; align-items: center;
  text-align: center;
  max-width: 760px; margin: 0 auto;
}
.hero-a-h1 {
  font-size: clamp(36px, 5vw, 64px);
  font-weight: 600;
  letter-spacing: -0.03em;
  line-height: 1.05;
  color: var(--ink);
  margin-bottom: 24px;
}
.hero-a-sub {
  font-size: clamp(16px, 2vw, 19px);
  color: var(--inkSoft);
  line-height: 1.6;
  max-width: 56ch;
  margin-bottom: 40px;
}
.hero-a-actions {
  display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;
  margin-bottom: 56px;
}
.trust-strip {
  width: 100%;
  border-top: 1px solid var(--lineSoft);
  padding-top: 32px;
  display: flex; flex-direction: column; align-items: center; gap: 16px;
}
.trust-label { margin: 0; }
.trust-items {
  display: flex; flex-wrap: wrap; justify-content: center; gap: 8px 24px;
}
.trust-item {
  font-size: 13px; color: var(--inkSoft); font-family: var(--fontMono);
}
.trust-item::before { content: '✓  '; color: var(--primary); }

/* ─── Variante B ─────────────────────────────────────────────────────────── */
.hero-b { padding-top: calc(68px + clamp(40px, 8vw, 80px)); }
.hero-b-inner {
  display: grid;
  grid-template-columns: 55fr 45fr;
  gap: clamp(40px, 6vw, 80px);
  align-items: center;
}
.hero-b-h1 {
  font-size: clamp(32px, 4.5vw, 58px);
  font-weight: 600; letter-spacing: -0.03em; line-height: 1.06;
  color: var(--ink); margin-bottom: 24px;
}
.hero-b-sub {
  font-size: clamp(15px, 1.8vw, 18px);
  color: var(--inkSoft); line-height: 1.65;
  max-width: 52ch; margin-bottom: 36px;
}
.hero-b-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 40px; }
.hero-b-divider { height: 1px; background: var(--lineSoft); margin-bottom: 20px; }
.hero-b-author { display: flex; align-items: center; gap: 14px; }
.author-avatar {
  width: 40px; height: 40px; border-radius: 50%;
  background: var(--lineSoft);
  flex-shrink: 0;
}
.author-name { font-size: 14px; font-weight: 500; color: var(--ink); margin-bottom: 2px; }
.author-sub { margin: 0; }

/* Image */
.hero-b-visual { position: relative; }
.hero-b-img {
  width: 100%;
  aspect-ratio: 4/5;
  border-radius: var(--radius-lg);
}
.hero-b-badge {
  position: absolute; bottom: -20px; left: -20px;
  background: var(--bgCard);
  border: 1px solid var(--lineSoft);
  border-radius: var(--radius-md);
  padding: 16px 20px;
  box-shadow: var(--shadow-md);
  min-width: 160px;
}
.badge-label { margin-bottom: 4px; }
.badge-value {
  font-size: 28px; font-weight: 600; color: var(--ink);
  letter-spacing: -0.02em; margin-bottom: 4px;
}

/* ─── Variante C ─────────────────────────────────────────────────────────── */
.hero-c { margin-top: 68px; }
.hero-c-visual {
  position: relative;
  width: 100%;
  aspect-ratio: 16/7;
  min-height: 400px;
  border-radius: 0;
  overflow: hidden;
}
.hero-c-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,.55) 0%, rgba(0,0,0,.0) 50%);
}
.hero-c-eyebrow-wrap {
  position: absolute; top: 28px; left: clamp(24px, 5vw, 60px);
}
.hero-c-eyebrow-pill {
  background: rgba(255,255,255,.88);
  backdrop-filter: blur(8px);
  padding: 6px 14px; border-radius: 100px;
  color: var(--ink); margin: 0;
}
.hero-c-h1-wrap {
  position: absolute; bottom: 36px; left: clamp(24px, 5vw, 60px);
  right: clamp(24px, 5vw, 60px);
}
.hero-c-h1 {
  font-size: clamp(28px, 5vw, 56px);
  font-weight: 600; letter-spacing: -0.03em; line-height: 1.08;
  color: #fff;
}
.hero-c-below { padding: clamp(36px, 5vw, 64px) 0; }
.hero-c-below-inner {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 48px; align-items: start;
}
.hero-c-sub {
  font-size: clamp(15px, 1.8vw, 18px); color: var(--inkSoft);
  line-height: 1.65; margin-bottom: 28px; max-width: 60ch;
}
.hero-c-actions { display: flex; gap: 12px; flex-wrap: wrap; }
.hero-c-infocard {
  background: var(--bgCard);
  border: 1px solid var(--lineSoft);
  border-radius: var(--radius-md);
  padding: 20px 24px;
  min-width: 200px;
  flex-shrink: 0;
}
.infocard-hours {
  font-size: 15px; font-weight: 600; color: var(--ink);
  margin: 6px 0 4px;
}
.infocard-location { font-size: 13px; }

/* ─── Responsive ─────────────────────────────────────────────────────────── */
@media (max-width: 900px) {
  .hero-b-inner { grid-template-columns: 1fr; }
  .hero-b-visual { display: none; }
  .hero-c-below-inner { grid-template-columns: 1fr; }
  .hero-c-infocard { max-width: 100%; }
}
@media (max-width: 600px) {
  .hero-a-actions, .hero-b-actions, .hero-c-actions {
    flex-direction: column;
  }
  .hero-a-actions .btn, .hero-b-actions .btn, .hero-c-actions .btn {
    width: 100%; justify-content: center;
  }
}
</style>
