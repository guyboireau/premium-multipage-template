---
// CTA finale — 2 variantes
// A : Fond contrasté (ink) avec invitation forte
// B : Minimaliste inline — titre + boutons sur fond paper
import { variants, cta } from '../config/site';

const v = variants.cta;
---

{/* ── Variante A : fond contrasté ────────────────────────────────────── */}
<section class="cta-a v-only-a" id="cta-a">
  <div class="container cta-a-inner">
    <div class="cta-a-content">
      <p class="eyebrow cta-a-eyebrow">{cta.eyebrow}</p>
      <h2 class="cta-a-h2">{cta.title}</h2>
      <p class="cta-a-sub">{cta.subtitle}</p>
    </div>
    <div class="cta-a-actions">
      <a href={cta.cta1.href} class="btn btn-lg cta-btn-primary">{cta.cta1.label}</a>
      <a href={cta.cta2.href} class="btn btn-lg cta-btn-ghost">{cta.cta2.label}</a>
    </div>
  </div>
</section>

{/* ── Variante B : minimaliste inline ────────────────────────────────── */}
<section class="section section-alt v-only-b v-only-c v-only-f v-only-h" id="cta-b">
  <div class="container cta-b-inner">
    <div>
      <p class="eyebrow">{cta.eyebrow}</p>
      <h2 class="cta-b-h2">{cta.title}</h2>
      <p class="cta-b-sub">{cta.subtitle}</p>
    </div>
    <div class="cta-b-actions">
      <a href={cta.cta1.href} class="btn btn-primary btn-lg">{cta.cta1.label}</a>
      <a href={cta.cta2.href} class="btn btn-outline btn-lg">{cta.cta2.label}</a>
    </div>
  </div>
</section>

{/* ── Variante E : Le Salon — fond encré sérifé ──────────────────────── */}
<section class="cta-e v-only-e" id="cta-e">
  <div class="container cta-e-inner">
    <div class="cta-e-ornement" aria-hidden="true">✦ &nbsp; {cta.eyebrow} &nbsp; ✦</div>
    <h2 class="cta-e-h2">{cta.title}</h2>
    <p class="cta-e-sub">{cta.subtitle}</p>
    <div class="cta-e-actions">
      <a href={cta.cta1.href} class="cta-e-btn-primary">{cta.cta1.label}</a>
      <a href={cta.cta2.href} class="cta-e-btn-ghost">{cta.cta2.label}</a>
    </div>
  </div>
</section>

{/* ── Variante G : Verveine — card peach arrondie ──────────────────────── */}
<section class="v-only-g cta-g-wrap" id="cta-g">
  <div class="container">
    <div class="cta-g">
      <div class="cta-g-blob-1" aria-hidden="true"></div>
      <div class="cta-g-blob-2" aria-hidden="true"></div>
      <div class="cta-g-content">
        <h2 class="cta-g-h2">{cta.title}</h2>
        <p class="cta-g-sub">{cta.subtitle}</p>
        <div class="cta-g-actions">
          <a href={cta.cta1.href} class="cta-g-btn-primary">{cta.cta1.label}</a>
        </div>
      </div>
    </div>
  </div>
</section>

{/* ── Variante D : Forge / fond ocre ──────────────────────────────────── */}
<section class="cta-d v-only-d" id="cta-d">
  <div class="container cta-d-inner">
    <h2 class="cta-d-h2">{cta.title}</h2>
    <div class="cta-d-right">
      <p class="cta-d-sub">{cta.subtitle}</p>
      <div class="cta-d-actions">
        <a href={cta.cta1.href} class="cta-d-btn-primary">{cta.cta1.label} →</a>
        <a href={cta.cta2.href} class="cta-d-btn-secondary">{cta.cta2.label}</a>
      </div>
    </div>
  </div>
</section>

<style>
/* ─── A ───────────────────────────────────────────────────────────────── */
.cta-a {
  background: var(--ink);
  padding: clamp(64px, 10vw, 120px) 0;
}
.cta-a-inner {
  display: flex; flex-direction: column; align-items: center;
  text-align: center; gap: 36px;
}
.cta-a-eyebrow { color: rgba(255,255,255,.45); }
.cta-a-h2 {
  font-size: clamp(28px, 4vw, 52px); font-weight: 600;
  letter-spacing: -0.03em; line-height: 1.1; color: #fff; margin: 0;
}
.cta-a-sub { font-size: 17px; color: rgba(255,255,255,.65); line-height: 1.6; max-width: 48ch; margin: 0; }
.cta-a-actions { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }

/* Boutons sur fond sombre */
.cta-btn-primary {
  background: #fff; color: var(--ink); border-color: #fff;
}
.cta-btn-primary:hover { background: rgba(255,255,255,.88); }
.cta-btn-ghost {
  background: transparent; color: rgba(255,255,255,.75); border-color: rgba(255,255,255,.25);
}
.cta-btn-ghost:hover { color: #fff; border-color: rgba(255,255,255,.6); }

/* ─── B ───────────────────────────────────────────────────────────────── */
.cta-b-inner {
  display: grid; grid-template-columns: 1fr auto; gap: 48px; align-items: center;
}
.cta-b-h2 {
  font-size: clamp(24px, 3vw, 38px); font-weight: 600;
  letter-spacing: -0.025em; line-height: 1.1; color: var(--ink); margin: 12px 0 12px;
}
.cta-b-sub { font-size: 15px; color: var(--inkSoft); margin: 0; }
.cta-b-actions { display: flex; flex-direction: column; gap: 10px; flex-shrink: 0; }

/* ─── Responsive ──────────────────────────────────────────────────────── */
@media (max-width: 768px) {
  .cta-a-actions, .cta-b-actions { flex-direction: column; align-items: stretch; }
  .cta-a-actions .btn, .cta-b-actions .btn { justify-content: center; }
  .cta-b-inner { grid-template-columns: 1fr; }
}

/* ─── E : Le Salon ───────────────────────────────────────────────────── */
.cta-e {
  background: #2c2520; color: #fbf6ec;
  padding: clamp(64px, 10vw, 96px) 0;
}
.cta-e-inner {
  display: flex; flex-direction: column; align-items: center;
  text-align: center; gap: 0;
}
.cta-e-ornement {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; color: #b8884a; letter-spacing: 0.3em;
  text-transform: uppercase; margin-bottom: 28px;
}
.cta-e-h2 {
  font-family: 'Newsreader', Georgia, serif;
  font-weight: 400; font-size: clamp(48px, 7vw, 88px);
  line-height: 1.0; letter-spacing: -0.03em; color: #fbf6ec;
  margin: 0 0 20px;
}
.cta-e-h2 em { font-style: italic; color: #b8884a; }
.cta-e-sub {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 17px; color: rgba(251,246,236,.6);
  max-width: 48ch; margin: 0 0 40px; line-height: 1.6;
}
.cta-e-actions { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; }
.cta-e-btn-primary {
  font-family: 'Plus Jakarta Sans', sans-serif; font-size: 15px;
  padding: 16px 28px; background: #fbf6ec; color: #2c2520;
  border: 1px solid #fbf6ec; border-radius: 0; text-decoration: none;
  transition: background 0.15s;
}
.cta-e-btn-primary:hover { background: #f4ede0; }
.cta-e-btn-ghost {
  font-family: 'Plus Jakarta Sans', sans-serif; font-size: 15px;
  padding: 16px 28px; background: transparent; color: #fbf6ec;
  border: 1px solid #b8884a; border-radius: 0; text-decoration: none;
}

/* ─── G : Verveine ────────────────────────────────────────────────────── */
.cta-g-wrap { padding: 32px 0 80px; }
.cta-g {
  background: #f5dac4; border-radius: 40px;
  padding: clamp(56px, 8vw, 80px) clamp(32px, 5vw, 56px);
  position: relative; overflow: hidden;
}
.cta-g-blob-1 {
  position: absolute; top: -40px; right: -40px;
  width: 280px; height: 280px; border-radius: 50%;
  background: #e8b896; opacity: 0.3;
}
.cta-g-blob-2 {
  position: absolute; bottom: -60px; left: -20px;
  width: 200px; height: 200px; border-radius: 50%;
  background: #cfd6c5; opacity: 0.4;
}
.cta-g-content { position: relative; max-width: 600px; }
.cta-g-h2 {
  font-family: 'Bricolage Grotesque', sans-serif; font-weight: 500;
  font-size: clamp(36px, 5vw, 60px);
  line-height: 1.05; letter-spacing: -0.03em; color: #3e4a3a;
  margin: 0 0 20px;
}
.cta-g-sub {
  font-family: 'DM Sans', sans-serif;
  font-size: 17px; color: #5a5f50; margin: 0 0 32px; line-height: 1.6; max-width: 48ch;
}
.cta-g-actions { display: flex; gap: 12px; }
.cta-g-btn-primary {
  font-family: 'DM Sans', sans-serif; font-weight: 500; font-size: 15px;
  padding: 14px 28px; background: #3e4a3a; color: #fbf8f0;
  border: 1.5px solid #3e4a3a; border-radius: 9999px; text-decoration: none;
  transition: background 0.15s;
}
.cta-g-btn-primary:hover { background: #2a3427; }

/* ─── D : Forge ──────────────────────────────────────────────────────── */
.cta-d {
  background: #c08c3c;
  padding: clamp(64px, 10vw, 96px) 0;
}
.cta-d-inner {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 64px; align-items: flex-end;
}
.cta-d-h2 {
  font-family: 'Archivo Black', sans-serif;
  font-size: clamp(48px, 7vw, 96px);
  line-height: 0.9; letter-spacing: -0.05em;
  text-transform: uppercase; color: #241c12; margin: 0;
}
.cta-d-right { display: flex; flex-direction: column; gap: 28px; }
.cta-d-sub {
  font-family: 'Manrope', sans-serif;
  font-size: 16px; color: #241c12; line-height: 1.6;
  max-width: 48ch; margin: 0;
}
.cta-d-actions { display: flex; gap: 10px; flex-wrap: wrap; }
.cta-d-btn-primary {
  font-family: 'Manrope', sans-serif; font-weight: 700;
  font-size: 13px; text-transform: uppercase; letter-spacing: 0.04em;
  padding: 14px 24px;
  background: #241c12; color: #ecdcbe;
  border: 2px solid #241c12; border-radius: 0;
  text-decoration: none; white-space: nowrap;
  transition: background 0.15s;
}
.cta-d-btn-primary:hover { background: #8a3a1e; border-color: #8a3a1e; }
.cta-d-btn-secondary {
  font-family: 'Manrope', sans-serif; font-weight: 700;
  font-size: 13px; text-transform: uppercase; letter-spacing: 0.04em;
  padding: 14px 24px;
  background: transparent; color: #241c12;
  border: 2px solid #241c12; border-radius: 0;
  text-decoration: none; white-space: nowrap;
  transition: background 0.15s, color 0.15s;
}
.cta-d-btn-secondary:hover { background: #241c12; color: #ecdcbe; }
@media (max-width: 768px) {
  .cta-d-inner { grid-template-columns: 1fr; gap: 32px; }
  .cta-d-actions { flex-direction: column; }
}
</style>
