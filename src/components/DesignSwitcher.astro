---
// DesignSwitcher — Outil de démo pour basculer entre les variantes A, B, C
---

<div class="ds-container" id="design-switcher">
  <button class="ds-toggle" aria-label="Paramètres de design">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
    </svg>
    <span>Démo Design</span>
  </button>

  <div class="ds-panel">
    <p class="ds-title">Variante Globale</p>
    <div class="ds-grid">
      <button class="ds-btn active" data-variant="A">
        <span class="ds-btn-mark">A</span>
        <span class="ds-btn-label">Classique</span>
      </button>
      <button class="ds-btn" data-variant="B">
        <span class="ds-btn-mark">B</span>
        <span class="ds-btn-label">Clean</span>
      </button>
      <button class="ds-btn" data-variant="C">
        <span class="ds-btn-mark">C</span>
        <span class="ds-btn-label">Édito</span>
      </button>
    </div>

    <div class="ds-sep"></div>

    <div class="ds-row">
      <label class="ds-switch-label" for="sketchy-toggle">Mode "Sketchy"</label>
      <input type="checkbox" id="sketchy-toggle" class="ds-checkbox" checked>
    </div>
  </div>
</div>

<script>
  const switcher = document.getElementById('design-switcher');
  const toggle = switcher?.querySelector('.ds-toggle');
  const btns = switcher?.querySelectorAll('.ds-btn');
  const sketchyToggle = document.getElementById('sketchy-toggle') as HTMLInputElement;

  // Toggle Panel
  toggle?.addEventListener('click', () => {
    switcher?.classList.toggle('open');
  });

  // Switch Variant
  btns?.forEach(btn => {
    btn.addEventListener('click', () => {
      const variant = btn.getAttribute('data-variant');
      if (!variant) return;

      // Update UI
      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      // Update Body Class
      document.body.classList.remove('v-a', 'v-b', 'v-c');
      document.body.classList.add(`v-${variant.toLowerCase()}`);
      
      // Save to localStorage for demo persistence
      localStorage.setItem('demo-variant', variant);
    });
  });

  // Toggle Sketchy
  sketchyToggle?.addEventListener('change', () => {
    document.body.classList.toggle('is-sketchy', sketchyToggle.checked);
    localStorage.setItem('demo-sketchy', String(sketchyToggle.checked));
  });

  // Load Initial State
  const savedVariant = localStorage.getItem('demo-variant') || 'A';
  const savedSketchy = localStorage.getItem('demo-sketchy') !== 'false'; // default true

  document.body.classList.add(`v-${savedVariant.toLowerCase()}`);
  document.body.classList.toggle('is-sketchy', savedSketchy);
  
  if (sketchyToggle) sketchyToggle.checked = savedSketchy;
  btns?.forEach(btn => {
    if (btn.getAttribute('data-variant') === savedVariant) {
      btn.classList.add('active');
    } else {
      btn.classList.remove('active');
    }
  });
</script>

<style>
  .ds-container {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9999;
    font-family: system-ui, -apple-system, sans-serif;
  }

  .ds-toggle {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    background: #1a1916;
    color: #fff;
    border: none;
    border-radius: 100px;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    font-weight: 600;
    font-size: 14px;
    transition: transform 0.2s;
  }
  .ds-toggle:hover { transform: scale(1.05); }

  .ds-panel {
    position: absolute;
    bottom: calc(100% + 12px);
    right: 0;
    width: 240px;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    opacity: 0;
    transform: translateY(10px);
    pointer-events: none;
    transition: all 0.2s;
  }
  .ds-container.open .ds-panel {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .ds-title {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #9ca3af;
    margin-bottom: 12px;
    font-weight: 700;
  }

  .ds-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-bottom: 16px;
  }

  .ds-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 10px 4px;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .ds-btn:hover { background: #f3f4f6; }
  .ds-btn.active {
    background: #f6e7d4;
    border-color: #b8763d;
    color: #b8763d;
  }

  .ds-btn-mark {
    font-size: 16px;
    font-weight: 800;
  }
  .ds-btn-label {
    font-size: 10px;
    font-weight: 500;
  }

  .ds-sep {
    height: 1px;
    background: #e5e7eb;
    margin: 16px 0;
  }

  .ds-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .ds-switch-label {
    font-size: 13px;
    font-weight: 500;
    color: #374151;
  }

  /* Checkbox switch style */
  .ds-checkbox {
    width: 36px;
    height: 20px;
    appearance: none;
    background: #d1d5db;
    border-radius: 20px;
    position: relative;
    cursor: pointer;
    outline: none;
    transition: background 0.2s;
  }
  .ds-checkbox:checked { background: #b8763d; }
  .ds-checkbox::before {
    content: '';
    position: absolute;
    width: 16px;
    height: 16px;
    background: white;
    border-radius: 50%;
    top: 2px;
    left: 2px;
    transition: transform 0.2s;
  }
  .ds-checkbox:checked::before { transform: translateX(16px); }
</style>
