---
// Header — 3 variantes
// A : Logo gauche · Nav centrée · CTA droite (classique)
// B : Logo + nav inline gauche · dispo + CTA droite  (Linear / Vercel)
// C : Identité forte (monogramme + tagline) · Menu bouton + CTA dominant
import { variants, business, nav } from '../config/site';

const v = variants.header;
const contactHref = nav.find(n => n.label === 'Contact')?.href || '#contact';
---

{/* ── Variante A : classique ──────────────────────────────────────────── */}
{v === 'A' && (
  <header class="hdr hdr-a" id="header">
    <div class="container hdr-inner">
      <a href="/" class="logo logo-a">
        <span class="logo-mark"></span>
        <span class="logo-name">{business.name}</span>
      </a>
      <nav class="nav-a" aria-label="Navigation principale">
        {nav.map(l => <a href={l.href} class="nav-link">{l.label}</a>)}
      </nav>
      <div class="hdr-actions-a">
        <a href={contactHref} class="btn btn-outline btn-sm">Connexion</a>
        <a href={contactHref} class="btn btn-primary btn-sm">Prendre RDV</a>
      </div>
      <button class="burger" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>
)}

{/* ── Variante B : Linear / Vercel style ─────────────────────────────── */}
{v === 'B' && (
  <header class="hdr hdr-b" id="header">
    <div class="container hdr-inner">
      <div class="hdr-left-b">
        <a href="/" class="logo logo-b">
          <span class="logo-mark"></span>
          <span class="logo-name text-mono" style="font-weight: 600;">studio</span>
        </a>
        <div class="hdr-sep" aria-hidden="true"></div>
        <nav class="nav-b" aria-label="Navigation principale">
          {nav.map(l => <a href={l.href} class="nav-link">{l.label}</a>)}
        </nav>
      </div>
      <div class="hdr-right-b">
        <span class="dispo-chip">
          <span class="dispo-dot" aria-hidden="true"></span>
          {business.availability}
        </span>
        <a href={contactHref} class="btn btn-primary btn-sm">Devis →</a>
      </div>
      <button class="burger" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span>
      </button>
    </div>
  </header>
)}

{/* ── Variante C : identité forte + Menu bouton ──────────────────────── */}
{v === 'C' && (
  <header class="hdr hdr-c" id="header">
    <div class="container hdr-inner">
      <a href="/" class="logo logo-c">
        <span class="logo-monogram" aria-hidden="true">
          {business.name.charAt(0)}
        </span>
        <span class="logo-text-c">
          <span class="logo-name">{business.name}</span>
          <span class="logo-tagline">{business.tagline}</span>
        </span>
      </a>
      <div class="hdr-right-c">
        <div class="dispo-chip hide-mobile">
          <span class="dispo-dot" aria-hidden="true"></span>
          <span class="text-faint">répond sous 24 h</span>
        </div>
        <button class="btn btn-outline btn-sm menu-toggle-c" aria-label="Ouvrir le menu" aria-expanded="false">
          <div class="menu-grid-icon" aria-hidden="true">
            <span></span><span></span><span></span><span></span>
          </div>
          Menu
        </button>
        <a href={contactHref} class="btn btn-primary btn-sm">Réserver un appel</a>
      </div>
    </div>
    {/* Full-screen overlay menu */}
    <div class="menu-overlay-c" id="menu-overlay-c" aria-hidden="true">
      <button class="overlay-close" aria-label="Fermer">✕</button>
      <nav class="overlay-nav" aria-label="Navigation principale">
        {nav.map(l => <a href={l.href} class="overlay-link">{l.label}</a>)}
      </nav>
      <a href={contactHref} class="btn btn-primary btn-lg overlay-cta">Réserver un appel</a>
    </div>
  </header>
)}

{/* ── Mobile menu (partagé A + B) ─────────────────────────────────────── */}
{(v === 'A' || v === 'B') && (
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true" role="dialog" aria-label="Menu mobile">
    <nav>
      {nav.map(l => <a href={l.href} class="mobile-link">{l.label}</a>)}
    </nav>
    <a href={contactHref} class="btn btn-primary" style="width: 100%; justify-content: center; margin-top: 8px;">
      Prendre RDV
    </a>
  </div>
)}

<script>
// Sticky shrink au scroll
const hdr = document.getElementById('header');
if (hdr) {
  const onScroll = () => hdr.classList.toggle('scrolled', window.scrollY > 20);
  window.addEventListener('scroll', onScroll, { passive: true });
}

// Burger mobile (variantes A + B)
const burger = document.querySelector('.burger');
const mobileMenu = document.getElementById('mobile-menu');
if (burger && mobileMenu) {
  burger.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    mobileMenu.setAttribute('aria-hidden', String(open));
    mobileMenu.classList.toggle('open', !open);
    document.body.style.overflow = open ? '' : 'hidden';
  });
  // Ferme au clic sur un lien
  mobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    burger.setAttribute('aria-expanded', 'false');
    mobileMenu.setAttribute('aria-hidden', 'true');
    mobileMenu.classList.remove('open');
    document.body.style.overflow = '';
  }));
}

// Overlay menu (variante C)
const menuToggleC = document.querySelector('.menu-toggle-c');
const overlayC = document.getElementById('menu-overlay-c');
const overlayClose = document.querySelector('.overlay-close');
if (menuToggleC && overlayC) {
  const openOverlay = () => {
    overlayC.classList.add('open');
    overlayC.setAttribute('aria-hidden', 'false');
    menuToggleC.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };
  const closeOverlay = () => {
    overlayC.classList.remove('open');
    overlayC.setAttribute('aria-hidden', 'true');
    menuToggleC.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  };
  menuToggleC.addEventListener('click', openOverlay);
  overlayClose?.addEventListener('click', closeOverlay);
  overlayC.querySelectorAll('a').forEach(a => a.addEventListener('click', closeOverlay));
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeOverlay(); });
}
</script>

<style>
/* ─── Base commune ─────────────────────────────────────────────────────── */
.hdr {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(250,249,247,.88);
  -webkit-backdrop-filter: blur(16px) saturate(140%);
  backdrop-filter: blur(16px) saturate(140%);
  border-bottom: 1px solid var(--lineSoft);
  transition: border-color 0.2s, box-shadow 0.2s, padding 0.2s;
}
.hdr.scrolled {
  border-color: var(--line);
  box-shadow: 0 1px 8px rgba(0,0,0,.06);
}
.hdr-inner {
  display: flex;
  align-items: center;
  height: 68px;
  gap: 24px;
}
.hdr.scrolled .hdr-inner { height: 56px; }

/* Logo */
.logo { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
.logo-mark {
  width: 22px; height: 22px;
  background: var(--ink);
  border-radius: 4px;
  flex-shrink: 0;
}
.logo-name {
  font-size: 14px; font-weight: 600; color: var(--ink);
  letter-spacing: -0.01em;
}

/* Nav link commun */
.nav-link {
  font-size: 13.5px; color: var(--inkSoft); font-weight: 400;
  transition: color 0.15s;
  white-space: nowrap;
}
.nav-link:hover { color: var(--ink); }

/* ─── Variante A ───────────────────────────────────────────────────────── */
.nav-a {
  display: flex; align-items: center; gap: 28px;
  margin-left: auto; margin-right: auto;
}
.hdr-actions-a { display: flex; gap: 10px; margin-left: auto; }

/* ─── Variante B ───────────────────────────────────────────────────────── */
.hdr-left-b { display: flex; align-items: center; gap: 16px; }
.hdr-sep {
  width: 1px; height: 20px;
  background: var(--line);
  flex-shrink: 0;
}
.nav-b { display: flex; align-items: center; gap: 24px; }
.hdr-right-b { display: flex; align-items: center; gap: 20px; margin-left: auto; }

/* ─── Variante C ───────────────────────────────────────────────────────── */
.logo-c { gap: 14px; }
.logo-monogram {
  width: 36px; height: 36px;
  background: var(--ink); color: var(--bg);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; font-weight: 700;
  flex-shrink: 0;
}
.logo-text-c { display: flex; flex-direction: column; gap: 1px; }
.logo-tagline { font-family: var(--mono); font-size: 10px; color: var(--inkFaint); }
.hdr-right-c { display: flex; align-items: center; gap: 16px; margin-left: auto; }
.menu-toggle-c { gap: 8px; }
.menu-grid-icon {
  display: grid; grid-template-columns: repeat(2, 1fr); gap: 2px;
  width: 10px; height: 10px;
}
.menu-grid-icon span { background: currentColor; width: 4px; height: 4px; }

/* Overlay menu C */
.menu-overlay-c {
  position: fixed; inset: 0; z-index: 200;
  background: var(--bg);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 32px;
  opacity: 0; pointer-events: none;
  transition: opacity 0.2s;
}
.menu-overlay-c.open { opacity: 1; pointer-events: auto; }
.overlay-close {
  position: absolute; top: 24px; right: 28px;
  background: none; border: none;
  font-size: 20px; color: var(--inkSoft); cursor: pointer;
}
.overlay-close:hover { color: var(--ink); }
.overlay-nav { display: flex; flex-direction: column; align-items: center; gap: 8px; }
.overlay-link {
  font-size: 28px; font-weight: 500; color: var(--ink);
  padding: 8px 0;
  transition: color 0.15s, transform 0.15s;
}
.overlay-link:hover { color: var(--inkSoft); transform: translateX(4px); }
.overlay-cta { margin-top: 8px; }

/* ─── Disponibilité chip ───────────────────────────────────────────────── */
.dispo-chip {
  display: flex; align-items: center; gap: 7px;
  font-family: var(--mono); font-size: 11px; color: var(--inkSoft);
  white-space: nowrap;
}
.dispo-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: #3f9c5a;
  flex-shrink: 0;
  box-shadow: 0 0 0 2px rgba(63,156,90,.18);
}

/* ─── Burger ───────────────────────────────────────────────────────────── */
.burger {
  display: none;
  flex-direction: column; justify-content: center; gap: 5px;
  width: 36px; height: 36px;
  background: none; border: none;
  padding: 6px; margin-left: auto;
}
.burger span {
  display: block; height: 1.5px; border-radius: 2px;
  background: var(--ink);
  transition: transform 0.2s, opacity 0.2s, width 0.2s;
}
.burger span:last-child { width: 70%; }
.burger[aria-expanded="true"] span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
.burger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); width: 100%; }

/* ─── Mobile menu drawer ───────────────────────────────────────────────── */
.mobile-menu {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 90;
  background: var(--bg);
  padding: 90px 28px 40px;
  display: flex; flex-direction: column; gap: 4px;
  transform: translateX(100%);
  transition: transform 0.25s cubic-bezier(0.3, 0.7, 0.4, 1);
}
.mobile-menu.open { transform: none; }
.mobile-link {
  display: block; padding: 14px 0;
  font-size: 20px; font-weight: 500; color: var(--ink);
  border-bottom: 1px solid var(--lineSoft);
}
.mobile-link:hover { color: var(--inkSoft); }

/* ─── Responsive ─────────────────────────────────────────────────────── */
@media (max-width: 900px) {
  .nav-a, .nav-b, .hdr-sep, .hdr-actions-a, .dispo-chip { display: none !important; }
  .hdr-right-b .btn, .hdr-right-c .dispo-chip { display: none !important; }
  .burger { display: flex !important; }
  .menu-toggle-c { display: none !important; }
}
@media (max-width: 600px) {
  .hdr-right-c { gap: 10px; }
  .logo-tagline { display: none; }
}
</style>
