---
// Header — 3 variantes
// A : Logo gauche · Nav centrée · CTA droite (classique)
// B : Logo + nav inline gauche · dispo + CTA droite  (Linear / Vercel)
// C : Identité forte (monogramme + tagline) · Menu bouton + CTA dominant
import { variants, business, nav, branding } from '../config/site';

const v = variants.header;
const contactHref = nav.find(n => n.label === 'Contact')?.href || '#contact';
---

{/* ── Variante A : classique ──────────────────────────────────────────── */}
<header class="hdr hdr-a v-only-a" id="main-header-a">
  <div class="container hdr-inner">
    <a href="/" class="logo" aria-label="Accueil">
      <img src={branding.logoPath} alt={business.name} height="32" />
      <span class="logo-text">{business.name}</span>
    </a>
    <nav class="nav-desktop" aria-label="Navigation principale">
      {nav.map(l => <a href={l.href} class="nav-link">{l.label}</a>)}
    </nav>
    <div class="hdr-actions-a">
      <a href={contactHref} class="btn btn-outline btn-sm">Connexion</a>
      <a href={contactHref} class="btn btn-primary btn-sm">Prendre RDV</a>
    </div>
    <button class="burger" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

{/* ── Variante B : Clean / Vercel style ──────────────────────────────── */}
<header class="hdr hdr-b v-only-b" id="main-header-b">
  <div class="container hdr-inner">
    <div class="hdr-left">
      <a href="/" class="logo-b" aria-label="Accueil">
        <img src={branding.logoPath} alt={business.name} height="24" />
      </a>
      <div class="hdr-sep" aria-hidden="true"></div>
      <nav class="nav-b">
        {nav.map(l => <a href={l.href} class="nav-link-b">{l.label}</a>)}
      </nav>
    </div>
    <div class="hdr-right">
      <span class="dispo-badge">
        <span class="dispo-dot" aria-hidden="true"></span>
        {business.availability}
      </span>
      <a href={contactHref} class="btn btn-primary btn-sm">Devis →</a>
    </div>
    <button class="burger" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span>
    </button>
  </div>
</header>

{/* ── Variante C : Identité Forte / Audacieux ────────────────────────── */}
<header class="hdr hdr-c v-only-c" id="main-header-c">
  <div class="container hdr-inner">
    <a href="/" class="logo-c">
      <div class="logo-mark">{business.name.charAt(0)}</div>
      <div class="logo-info">
        <span class="logo-name">{business.name}</span>
        <span class="logo-tag">{business.tagline}</span>
      </div>
    </a>
    <div class="hdr-actions-c">
      <button class="menu-trigger" id="overlay-open">
        <div class="menu-icon">
          <span></span><span></span>
        </div>
        Menu
      </button>
      <a href={contactHref} class="btn btn-primary btn-sm">Réserver un appel</a>
    </div>
  </div>
  {/* Full-screen overlay menu */}
  <div class="overlay-menu" id="overlay-nav">
    <button class="overlay-close" id="overlay-close">&times;</button>
    <nav class="overlay-nav" aria-label="Navigation principale">
      {nav.map(l => <a href={l.href} class="overlay-link">{l.label}</a>)}
    </nav>
    <a href={contactHref} class="btn btn-primary btn-lg overlay-cta">Réserver un appel</a>
  </div>
</header>

{/* ── Mobile menu (partagé A + B) ─────────────────────────────────────── */}
<div class="mobile-menu" id="mobile-menu" aria-hidden="true" role="dialog" aria-label="Menu mobile">
  <nav>
    {nav.map(l => <a href={l.href} class="mobile-link">{l.label}</a>)}
  </nav>
  <a href={contactHref} class="btn btn-primary" style="width: 100%; justify-content: center; margin-top: 8px;">
    Prendre RDV
  </a>
</div>

<script>
// Logic for scroll effect
const headers = document.querySelectorAll('.hdr');
if (headers.length > 0) {
  const onScroll = () => headers.forEach(h => h.classList.toggle('scrolled', window.scrollY > 20));
  window.addEventListener('scroll', onScroll, { passive: true });
}

// Burger mobile (variantes A + B)
const burgers = document.querySelectorAll('.burger');
const mobileMenu = document.getElementById('mobile-menu');
if (burgers.length > 0 && mobileMenu) {
  burgers.forEach(burger => {
    burger.addEventListener('click', () => {
      const open = burger.getAttribute('aria-expanded') === 'true';
      burgers.forEach(b => b.setAttribute('aria-expanded', String(!open)));
      mobileMenu.setAttribute('aria-hidden', String(open));
      mobileMenu.classList.toggle('open', !open);
      document.body.style.overflow = open ? '' : 'hidden';
    });
  });
  // Ferme au clic sur un lien
  mobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    burgers.forEach(b => b.setAttribute('aria-expanded', 'false'));
    mobileMenu.setAttribute('aria-hidden', 'true');
    mobileMenu.classList.remove('open');
    document.body.style.overflow = '';
  }));
}

// Overlay menu (variante C)
const menuTrigger = document.getElementById('overlay-open');
const overlayNav = document.getElementById('overlay-nav');
const overlayClose = document.getElementById('overlay-close');
if (menuTrigger && overlayNav) {
  const openOverlay = () => {
    overlayNav.classList.add('open');
    document.body.style.overflow = 'hidden';
  };
  const closeOverlay = () => {
    overlayNav.classList.remove('open');
    document.body.style.overflow = '';
  };
  menuTrigger.addEventListener('click', openOverlay);
  overlayClose?.addEventListener('click', closeOverlay);
  overlayNav.querySelectorAll('a').forEach(a => a.addEventListener('click', closeOverlay));
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeOverlay(); });
}
</script>

<style>
/* ─── Base commune ─────────────────────────────────────────────────────── */
.hdr {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(250,249,247,.88);
  -webkit-backdrop-filter: blur(16px) saturate(140%);
  backdrop-filter: blur(16px) saturate(140%);
  border-bottom: 1px solid var(--lineSoft);
  transition: border-color 0.2s, box-shadow 0.2s, padding 0.2s;
}
.hdr.scrolled {
  border-color: var(--line);
  box-shadow: 0 1px 8px rgba(0,0,0,.06);
}
.hdr-inner {
  display: flex;
  align-items: center;
  height: 68px;
  gap: 24px;
}
.hdr.scrolled .hdr-inner { height: 56px; }

/* Logo */
.logo, .logo-b, .logo-c { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
.logo-text { font-size: 14px; font-weight: 600; color: var(--ink); }

/* Nav link commun */
.nav-link, .nav-link-b {
  font-size: 13.5px; color: var(--inkSoft); font-weight: 400;
  transition: color 0.15s;
  white-space: nowrap;
}
.nav-link:hover, .nav-link-b:hover { color: var(--ink); }

/* ─── Variante A ───────────────────────────────────────────────────────── */
.nav-desktop {
  display: flex; align-items: center; gap: 28px;
  margin-left: auto; margin-right: auto;
}
.hdr-actions-a { display: flex; gap: 10px; margin-left: auto; }

/* ─── Variante B ───────────────────────────────────────────────────────── */
.hdr-left { display: flex; align-items: center; gap: 20px; }
.hdr-sep { width: 1px; height: 20px; background: var(--line); }
.nav-b { display: flex; align-items: center; gap: 24px; }
.hdr-right { display: flex; align-items: center; gap: 20px; margin-left: auto; }
.dispo-badge {
  display: flex; align-items: center; gap: 7px;
  font-family: var(--fontMono); font-size: 11px; color: var(--inkSoft);
}
.dispo-dot { width: 7px; height: 7px; border-radius: 50%; background: #3f9c5a; }

/* ─── Variante C ───────────────────────────────────────────────────────── */
.logo-mark {
  width: 36px; height: 36px; background: var(--ink); color: #fff;
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  font-weight: 700;
}
.logo-info { display: flex; flex-direction: column; line-height: 1.2; }
.logo-name { font-size: 14px; font-weight: 600; }
.logo-tag { font-size: 10px; color: var(--inkSoft); font-family: var(--fontMono); }

.hdr-actions-c { display: flex; align-items: center; gap: 16px; margin-left: auto; }
.menu-trigger {
  display: flex; align-items: center; gap: 8px;
  background: none; border: none; font-size: 14px; font-weight: 500; cursor: pointer;
}
.menu-icon { display: flex; flex-direction: column; gap: 4px; }
.menu-icon span { width: 16px; height: 1.5px; background: var(--ink); }

.overlay-menu {
  position: fixed; inset: 0; background: var(--bg); z-index: 200;
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 32px;
  opacity: 0; pointer-events: none; transition: opacity 0.3s;
}
.overlay-menu.open { opacity: 1; pointer-events: auto; }
.overlay-close { position: absolute; top: 24px; right: 24px; font-size: 32px; background: none; border: none; cursor: pointer; }
.overlay-nav { display: flex; flex-direction: column; align-items: center; gap: 16px; }
.overlay-link { font-size: 24px; font-weight: 600; }

/* ─── Burger ───────────────────────────────────────────────────────────── */
.burger {
  display: none; flex-direction: column; gap: 5px; width: 32px;
  background: none; border: none; cursor: pointer; padding: 0;
}
.burger span { height: 1.5px; background: var(--ink); transition: 0.2s; }
.burger[aria-expanded="true"] span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
.burger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

.mobile-menu {
  position: fixed; inset: 0; background: var(--bg); z-index: 90;
  padding: 100px 24px; display: flex; flex-direction: column; gap: 10px;
  transform: translateX(100%); transition: transform 0.3s;
}
.mobile-menu.open { transform: translateX(0); }
.mobile-link { font-size: 18px; font-weight: 500; padding: 12px 0; border-bottom: 1px solid var(--lineSoft); }

@media (max-width: 900px) {
  .nav-desktop, .hdr-actions-a, .hdr-left .hdr-sep, .hdr-left .nav-b, .hdr-right { display: none; }
  .burger { display: flex; }
}
</style>
