---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

import { business, pages, portfolio } from '../config/site';
---

<Layout
  title={`${pages.realisations.title} | ${business.name}`}
  description={pages.realisations.description}
>
  <Header />
  <main id="main-content">
    <section class="section" style="padding-top: 120px;">
      <div class="container">
        <p class="eyebrow">— Nos réalisations</p>
        <h1 style="font-size: clamp(32px, 5vw, 48px); font-weight: 600; margin: 12px 0 48px;">Nos Derniers Chantiers</h1>
        
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 32px;">
          {portfolio.items.map(item => (
            <article class="card">
              <div class="img-placeholder" style="aspect-ratio: 4/3; border-radius: var(--radius-md) var(--radius-md) 0 0;"></div>
              <div style="padding: 24px;">
                <p class="eyebrow" style="margin-bottom: 8px;">{item.category}</p>
                <h3 style="font-size: 20px; font-weight: 600; color: var(--ink);">{item.title}</h3>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
    <CTA />
  </main>
  <Footer />
</Layout>
