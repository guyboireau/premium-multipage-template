---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Services from '../components/Services.astro';
import Certifications from '../components/Certifications.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import UrgentFloat from '../components/UrgentFloat.astro';

import { business, pages, seo, content } from '../config/site';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  provider: {
    '@type': 'LocalBusiness',
    name: business.name,
    telephone: business.phone,
    url: seo.siteUrl,
  },
  areaServed: business.serviceArea.map(area => ({ '@type': 'City', name: area })),
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: pages.services.title,
    itemListElement: content.services.items.map((s, i) => ({
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: s.title, description: s.text },
      position: i + 1,
    })),
  },
};
---

<Layout
  title={`${pages.services.title} | ${business.name}`}
  description={pages.services.description}
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <Header />
  <main id="main-content">
    <div style="padding-top: 80px;">
      <div class="container" style="padding-top: 40px;">
        <Breadcrumb items={[
          { label: 'Accueil', href: '/' },
          { label: pages.services.title },
        ]} />
      </div>
      <Services />
    </div>
    <Certifications />
    <section class="section section-alt">
      <div class="container">
        <div style="max-width: 800px; margin: 0 auto; text-align: center;">
          <p class="eyebrow">— Notre Méthode</p>
          <h2 style="font-size: 32px; font-weight: 600; margin: 12px 0 32px;">Comment nous travaillons</h2>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 40px; text-align: left;">
            <div>
              <span style="font-family: var(--mono); font-size: 24px; color: var(--line);">01</span>
              <h3 style="font-size: 18px; font-weight: 600; margin: 8px 0;">Diagnostic</h3>
              <p class="text-muted">Visite gratuite et devis précis sous 48h.</p>
            </div>
            <div>
              <span style="font-family: var(--mono); font-size: 24px; color: var(--line);">02</span>
              <h3 style="font-size: 18px; font-weight: 600; margin: 8px 0;">Devis</h3>
              <p class="text-muted">Proposition détaillée, sans surprise cachée.</p>
            </div>
            <div>
              <span style="font-family: var(--mono); font-size: 24px; color: var(--line);">03</span>
              <h3 style="font-size: 18px; font-weight: 600; margin: 8px 0;">Réalisation</h3>
              <p class="text-muted">Travaux réalisés par nos artisans certifiés.</p>
            </div>
            <div>
              <span style="font-family: var(--mono); font-size: 24px; color: var(--line);">04</span>
              <h3 style="font-size: 18px; font-weight: 600; margin: 8px 0;">Garantie</h3>
              <p class="text-muted">Garantie décennale + suivi post-chantier.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
    <CTA />
  </main>
  <Footer />
  <UrgentFloat />
</Layout>
