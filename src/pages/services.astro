---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Services from '../components/Services.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

import { business, pages } from '../config/site';
---

<Layout
  title={`${pages.services.title} | ${business.name}`}
  description={pages.services.description}
>
  <Header />
  <main id="main-content">
    <div style="padding-top: 80px;">
      <Services />
    </div>
    <section class="section section-alt">
      <div class="container">
        <div style="max-width: 800px; margin: 0 auto; text-align: center;">
          <p class="eyebrow">— Notre Méthode</p>
          <h2 style="font-size: 32px; font-weight: 600; margin: 12px 0 32px;">Comment nous travaillons</h2>
          
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 40px; text-align: left;">
            <div>
              <span style="font-family: var(--mono); font-size: 24px; color: var(--line);">01</span>
              <h3 style="font-size: 18px; font-weight: 600; margin: 8px 0;">Consultation</h3>
              <p class="text-muted">Étude de votre projet et établissement d'un devis précis.</p>
            </div>
            <div>
              <span style="font-family: var(--mono); font-size: 24px; color: var(--line);">02</span>
              <h3 style="font-size: 18px; font-weight: 600; margin: 8px 0;">Conception</h3>
              <p class="text-muted">Choix des matériaux et planification détaillée du chantier.</p>
            </div>
            <div>
              <span style="font-family: var(--mono); font-size: 24px; color: var(--line);">03</span>
              <h3 style="font-size: 18px; font-weight: 600; margin: 8px 0;">Réalisation</h3>
              <p class="text-muted">Exécution des travaux par nos artisans qualifiés.</p>
            </div>
            <div>
              <span style="font-family: var(--mono); font-size: 24px; color: var(--line);">04</span>
              <h3 style="font-size: 18px; font-weight: 600; margin: 8px 0;">Livraison</h3>
              <p class="text-muted">Contrôle qualité et remise des clés de votre nouvel espace.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
    <CTA />
  </main>
  <Footer />
</Layout>
